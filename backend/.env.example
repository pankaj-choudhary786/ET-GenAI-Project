# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# MongoDB
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/ai-sales-crm?retryWrites=true&w=majority

# JWT
JWT_SECRET=replace_with_a_very_long_random_string_at_least_64_chars
JWT_EXPIRES_IN=7d

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Gmail SMTP
GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password_16chars

# HubSpot CRM
HUBSPOT_API_KEY=your_hubspot_private_app_token

# Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# Session secret
SESSION_SECRET=another_long_random_string_for_sessions
